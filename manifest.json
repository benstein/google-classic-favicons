{
  "manifest_version": 3,
  "name": "Google Workspace Classic Favicons",
  "version": "1.0.0",
  "description": "Restores the pre-2026 Google Workspace favicons (Gmail, Calendar, Drive, Docs, Sheets, Slides, Meet).",
  "icons": {
    "16": "icons/extension16.png",
    "48": "icons/extension48.png",
    "128": "icons/extension128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mail.google.com/*",
        "https://calendar.google.com/*",
        "https://drive.google.com/*",
        "https://docs.google.com/*",
        "https://meet.google.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": [
        "https://mail.google.com/*",
        "https://calendar.google.com/*",
        "https://drive.google.com/*",
        "https://docs.google.com/*",
        "https://meet.google.com/*"
      ]
    }
  ]
}
